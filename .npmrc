# Always pin exact versions on `pnpm add` (no ^ or ~ prefix).
# Keeps installs deterministic between local dev, CI, and release builds.
save-exact=true

# Block install if engines.node / engines.pnpm in package.json don't match the
# current toolchain — surfaces "wrong Node version" before pnpm 11 dies with
# ERR_UNKNOWN_BUILTIN_MODULE: node:sqlite.
engine-strict=true
