{
  "name": "prism",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Cross-platform desktop dashboard for managing GitHub pull requests.",
  "license": "MIT",
  "engines": {
    "node": ">=22.13",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.1.2",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "vue-demi"]
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "typecheck": "vue-tsc --noEmit",
    "lint": "echo 'lint wiring lands in a follow-up PR' && exit 0"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/plugin-opener": "2.5.4",
    "@vueuse/core": "13.9.0",
    "pinia": "3.0.4",
    "reka-ui": "2.9.7",
    "vue": "3.5.34",
    "vue-router": "4.6.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.0",
    "@tauri-apps/cli": "2.11.2",
    "@types/node": "22.19.19",
    "@vitejs/plugin-vue": "5.2.4",
    "tailwindcss": "4.3.0",
    "typescript": "5.7.3",
    "vite": "6.4.2",
    "vue-tsc": "2.2.12"
  }
}
