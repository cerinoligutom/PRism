{
  "name": "prism",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Cross-platform desktop dashboard for managing GitHub pull requests.",
  "license": "MIT",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.1.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "vue-demi"
    ]
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "typecheck": "vue-tsc --noEmit",
    "lint": "echo 'lint wiring lands in a follow-up PR' && exit 0",
    "bump-version": "node --experimental-strip-types scripts/bump-version.ts",
    "check-version": "node --experimental-strip-types scripts/bump-version.ts --check"
  },
  "dependencies": {
    "@fontsource/mona-sans": "^5.2.8",
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/plugin-notification": "2.3.3",
    "@tauri-apps/plugin-opener": "2.5.4",
    "@vueuse/core": "14.3.0",
    "dompurify": "3.4.5",
    "pinia": "3.0.4",
    "reka-ui": "2.9.7",
    "shiki": "4.1.0",
    "vue": "3.5.34",
    "vue-router": "5.0.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.0",
    "@tauri-apps/cli": "2.11.2",
    "@types/node": "24.12.4",
    "@vitejs/plugin-vue": "6.0.7",
    "esbuild": "0.28.0",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vite": "8.0.13",
    "vue-tsc": "3.3.1"
  }
}
